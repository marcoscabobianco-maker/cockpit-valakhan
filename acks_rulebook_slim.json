{"settlements":{"_doc":"ACKS Rulebook Ch.8 — Visiting Settlements. Market Class determines availability, services, encounters.","market_classes":{"I":{"label":"Class I — Metropolitan","population":"100,000+","families":"20,000+","services":"All available, including 6th level magic","loanable_funds_gp":100000,"investment_opportunities_gp":100000},"II":{"label":"Class II — Urban","population":"20,000-99,999","families":"5,000+","services":"Most services, 5th level magic","loanable_funds_gp":25000,"investment_opportunities_gp":25000},"III":{"label":"Class III — Large Town","population":"5,000-19,999","families":"1,250+","services":"Many services, 4th level magic","loanable_funds_gp":5000,"investment_opportunities_gp":5000},"IV":{"label":"Class IV — Town","population":"1,250-4,999","families":"300+","services":"Basic services, 3rd level magic, henchmen 1d6+3/wk","loanable_funds_gp":1250,"investment_opportunities_gp":1250},"V":{"label":"Class V — Village","population":"300-1,249","families":"75+","services":"Limited services, 2nd level magic","loanable_funds_gp":250,"investment_opportunities_gp":250},"VI":{"label":"Class VI — Hamlet","population":"75-299","families":"20+","services":"Very limited, 1st level magic only","loanable_funds_gp":50,"investment_opportunities_gp":50}},"_settlement_encounters_doc":"ACKS RB Ch.8 Visiting Settlements section has hourly encounter checks by district (Avenue/Slums/Temple District/etc.)"},"mercantile":{"_doc":"ACKS Rulebook Ch.8 — Mercantile Ventures. Trade routes between settlements. Supply & Demand drives prices.","process":["1. Buy goods at Class A market (baseline_price)","2. Travel to Class B market (consume Supply, encounter checks)","3. Roll Supply & Demand (2d6 + modifiers)","4. Apply price modifier from result","5. Sell goods at modified price"],"supply_demand_mechanic":{"_doc":"JJ Ch.2 — Mercantile Ventures","die":"2d6","modifiers":["+1 if destination is Class I or II","+1 if Class A goods to Class B markets","-1 if same class market","-1 if Class B goods returning to Class A","+1 per neighboring market with shortage of this good","-1 per neighboring market with surplus"],"results":{"2-":"Outraged refusal — cannot sell","3-5":"Reluctant purchase — 50% baseline","6-8":"Standard market — 100% baseline","9-11":"Eager market — 120% baseline","12+":"Frenzy — 150% baseline"}},"baseline_cargo_by_class":{"I":{"cargo_st":30000,"toll_cp_per_st":0.2,"tariff_pct":25},"II":{"cargo_st":15000,"toll_cp_per_st":0.4,"tariff_pct":20},"III":{"cargo_st":6000,"toll_cp_per_st":0.6,"tariff_pct":15},"IV":{"cargo_st":1500,"toll_cp_per_st":1.0,"tariff_pct":10},"V":{"cargo_st":400,"toll_cp_per_st":1.5,"tariff_pct":5},"VI":{"cargo_st":100,"toll_cp_per_st":2.0,"tariff_pct":0}}}}